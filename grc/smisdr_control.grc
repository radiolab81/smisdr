    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 16.0]
    rotation: 0
    state: enabled
- name: rate_scale
  id: variable
  parameters:
    comment: Skalierungsfaktor Hz -> Kommandowert, ggf. anpassen!
    value: '1000000.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [696, 16.0]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: Ziel-Samplerate in Hz, z.B. 1250000 -> "rate 1.25"
