- name: samp_rate_to_msg
  id: blocks_var_to_msg
  parameters:
    affinity: ''
    alias: ''
    comment: Feuert NUR bei tatsaechlicher Aenderung von samp_rate zur Laufzeit (kein
      Timer)
    maxoutbuf: '0'
    minoutbuf: '0'
    msgname: rate
    target: samp_rate
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [24, 296.0]
    rotation: 0
    state: enabled
- name: send_initial_rate
  id: snippet
  parameters:
    alias: ''
    code: self.epy_block_rate_sender.send_now(self.samp_rate)
    comment: Sendet die aktuelle Samplerate GENAU EINMAL, direkt nachdem der Flowgraph
      gestartet wurde. Kein Timer, keine Wiederholung.
    priority: '0'
    section: main_after_start
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [24, 552.0]
    rotation: 0
    state: enabled

connections:
- [btn_width_16, pressed, epy_block_width16_sender, trigger]
- [btn_width_8, pressed, epy_block_width8_sender, trigger]
- [samp_rate_to_msg, msgout, epy_block_rate_sender, msg_in]

metadata:
  file_format: 1
  grc_version: 3.10.12.0
