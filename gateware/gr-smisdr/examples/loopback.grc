    comment: ''
    stream_id: TX
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [480, 488.0]
    rotation: 0
    state: enabled

connections:
- [blocks_file_source_0, '0', smisdr_decoder_0, '0']
- [blocks_float_to_complex_0, '0', blocks_throttle2_0, '0']
- [blocks_throttle2_0, '0', smisdr_encoder_0, '0']
- [blocks_wavfile_source_0, '0', blocks_float_to_complex_0, '0']
- [blocks_wavfile_source_0, '1', blocks_float_to_complex_0, '1']
- [smisdr_decoder_0, '0', qtgui_sink_x_0, '0']
- [smisdr_decoder_0, cmd, blocks_message_debug_0, print]
- [smisdr_encoder_0, '0', blocks_file_sink_0, '0']
- [smisdr_encoder_0, '0', virtual_sink_0, '0']
- [virtual_source_0, '0', smisdr_decoder_0, '0']

metadata:
  file_format: 1
  grc_version: 3.10.12.0
