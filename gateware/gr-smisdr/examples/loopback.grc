    state: enabled
- name: smisdr_decoder_0
  id: smisdr_decoder
  parameters:
    affinity: ''
    alias: ''
    cmd_timeout_words: '0'
    comment: ''
    master_clock: 50e6
    maxoutbuf: '0'
    minoutbuf: '0'
    scale: '8191'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [696, 472.0]
    rotation: 0
    state: enabled
- name: smisdr_encoder_0
  id: smisdr_encoder
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    inject_at_start: 'True'
    master_clock: 50e6
    maxoutbuf: '0'
    minoutbuf: '0'
